{
    "name": "pingdart-node",
    "version": "1.1.3",
    "description": "Official JavaScript SDK for PingDart platform",
    "type": "module",
    "main": "src/index.js",
    "exports": {
        ".": "./src/index.js"
    },
    "scripts": {
        "test": "NODE_OPTIONS=--experimental-vm-modules npx jest",
        "release": "npm version patch && npm publish",
        "release:minor": "npm version minor && npm publish",
        "release:major": "npm version major && npm publish"
    },
    "homepage": "https://pingdart.com",
    "repository": {
        "type": "git",
        "url": "https://github.com/pingdart/pingdart-node.git"
    },
    "publishConfig": {
        "access": "public"
    },
    "config": {
        "apiUrl": "https://cloudapi.pingdart.com/api"
    },
    "keywords": [
        "sdk",
        "api",
        "whatsapp",
        "sms",
        "pingdart"
    ],
    "author": "PingDart",
    "license": "MIT",
    "dependencies": {
        "axios": "^1.6.0",
        "socket.io-client": "^4.8.3"
    },
    "devDependencies": {
        "jest": "^30.3.0"
    }
}